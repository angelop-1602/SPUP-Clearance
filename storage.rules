rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public write access for submissions (students can upload)
    // Allow public read access (download URLs work, but URLs are only in admin-accessible Firestore)
    match /submissions/{fileName} {
      // Allow anyone to write (upload) submissions
      allow write: if true;
      // Allow public read (download URLs work, but URLs are stored in Firestore which requires admin access)
      allow read: if true;
    }
    
    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
